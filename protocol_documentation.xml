        </thead>
        <tbody>
          <tr><td><tt>CMD_LOGIN</tt></td><td><tt>PayloadReqLogin</tt></td><td><tt>RPL_OK</tt></td><td><tt>ERR_ALREADY_EXIST</tt>, <tt>ERR_BAD_REQUEST</tt></td></tr>
          <tr><td><tt>CMD_LOGOUT</tt></td><td><em>(none)</em></td><td><tt>RPL_OK</tt></td><td><tt>ERR_UNAUTHORIZED</tt></td></tr>
          <tr><td><tt>CMD_USERS</tt></td><td><em>(none)</em></td><td><tt>RPL_USERS_LIST</tt> x N, <tt>RPL_OK</tt></td><td><tt>ERR_UNAUTHORIZED</tt></td></tr>
