          <tr><td><tt>CMD_MESSAGES</tt></td><td><tt>PayloadReqTargetUser</tt></td><td><tt>RPL_MESSAGES_LIST</tt> x N, <tt>RPL_OK</tt></td><td><tt>ERR_NOT_FOUND</tt>, <tt>ERR_UNAUTHORIZED</tt></td></tr>
          <tr><td><tt>CMD_SUBSCRIBE</tt></td><td><tt>PayloadReqTeamTarget</tt></td><td><tt>RPL_OK</tt></td><td><tt>ERR_NOT_FOUND</tt>, <tt>ERR_ALREADY_EXIST</tt></td></tr>
          <tr><td><tt>CMD_UNSUBSCRIBE</tt></td><td><tt>PayloadReqTeamTarget</tt></td><td><tt>RPL_OK</tt></td><td><tt>ERR_NOT_FOUND</tt>, <tt>ERR_FORBIDDEN</tt></td></tr>
          <tr><td><tt>CMD_SUBSCRIBED_LIST</tt></td><td><em>(none)</em></td><td><tt>RPL_SUBSCRIBED_LIST</tt> x N, <tt>RPL_OK</tt></td><td><tt>ERR_UNAUTHORIZED</tt></td></tr>
          <tr><td><tt>CMD_USE</tt></td><td><tt>PayloadReqTeamTarget</tt></td><td><tt>RPL_OK</tt></td><td><tt>ERR_NOT_FOUND</tt>, <tt>ERR_FORBIDDEN</tt></td></tr>
          <tr><td><tt>CMD_CREATE</tt> (team)</td><td><tt>PayloadReqCreateTeam</tt></td><td><tt>RPL_CREATED</tt> + <tt>EVT_TEAM_CREATED</tt> to all</td><td><tt>ERR_ALREADY_EXIST</tt></td></tr>
          <tr><td><tt>CMD_CREATE</tt> (channel)</td><td><tt>PayloadReqCreateChannel</tt></td><td><tt>RPL_CREATED</tt> + <tt>EVT_CHANNEL_CREATED</tt> to subscribers</td><td><tt>ERR_ALREADY_EXIST</tt>, <tt>ERR_FORBIDDEN</tt></td></tr>
          <tr><td><tt>CMD_CREATE</tt> (thread)</td><td><tt>PayloadReqCreateThread</tt></td><td><tt>RPL_CREATED</tt> + <tt>EVT_THREAD_CREATED</tt> to subscribers</td><td><tt>ERR_FORBIDDEN</tt></td></tr>
          <tr><td><tt>CMD_CREATE</tt> (reply)</td><td><tt>PayloadReqCreateReply</tt></td><td><tt>RPL_CREATED</tt> + <tt>EVT_REPLY_CREATED</tt> to subscribers</td><td><tt>ERR_FORBIDDEN</tt></td></tr>
          <tr><td><tt>CMD_LIST</tt> (teams)</td><td><em>(none)</em></td><td><tt>RPL_TEAMS_LIST</tt> x N, <tt>RPL_OK</tt></td><td><tt>ERR_UNAUTHORIZED</tt></td></tr>
          <tr><td><tt>CMD_LIST</tt> (channels)</td><td><em>(none)</em></td><td><tt>RPL_CHANNELS_LIST</tt> x N, <tt>RPL_OK</tt></td><td><tt>ERR_FORBIDDEN</tt></td></tr>
          <tr><td><tt>CMD_LIST</tt> (threads)</td><td><em>(none)</em></td><td><tt>RPL_THREADS_LIST</tt> x N, <tt>RPL_OK</tt></td><td><tt>ERR_FORBIDDEN</tt></td></tr>
          <tr><td><tt>CMD_INFO</tt></td><td><em>(none)</em></td><td>Context-dependent reply</td><td><tt>ERR_BAD_REQUEST</tt></td></tr>
